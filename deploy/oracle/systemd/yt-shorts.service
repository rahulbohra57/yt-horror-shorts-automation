[Unit]
Description=YT Shorts Bot FastAPI Service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/yt-shorts
EnvironmentFile=/opt/yt-shorts/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/yt-shorts/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
